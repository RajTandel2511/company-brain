# ---- Spectrum (Trimble / Viewpoint) SQL Server — READ ONLY ----
SPECTRUM_SQL_HOST=xxxxxxxxxxxxxxxxxxx
SPECTRUM_SQL_PORT=1433
SPECTRUM_SQL_DATABASE=Spectrum
SPECTRUM_SQL_USER=xxxxxxx
SPECTRUM_SQL_PASSWORD=xxxxxxxxx
SPECTRUM_SQL_ENCRYPT=yes
SPECTRUM_SQL_TRUST_CERT=yes

# Multi-company: your operating company code (e.g. AA1). Everything is filtered
# by this unless the user explicitly asks about another company.
SPECTRUM_COMPANY_CODE=AA1

# ---- LLM provider ----
# "anthropic" (cloud, cheap with Haiku) or "ollama" (local, free if you have a GPU)
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic). Haiku 4.5 is ~15x cheaper than Opus.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Optional: use a bigger model only for the final summary step. Leave blank to
# use ANTHROPIC_MODEL everywhere. Setting this gives you Haiku speed/price for
# SQL generation and better writing on the summary.
ANTHROPIC_SUMMARY_MODEL=

# Ollama (used when LLM_PROVIDER=ollama). Point at a local Ollama server.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Response cache — hash of (question + schema snapshot). TTL in seconds.
RESPONSE_CACHE_TTL=3600

# ---- Synology NAS mount (path INSIDE the backend container) ----
# Host path is set in docker-compose.yml, e.g. /volume1/projects -> /mnt/nas
NAS_ROOT=/mnt/nas

# ---- App ----
APP_SECRET=change-me-long-random-string
ALLOWED_ORIGINS=http://localhost:8080,http://synology.local:8080
FRONTEND_PORT=8080
BACKEND_PORT=8000
